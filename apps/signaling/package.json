{
  "name": "signaling",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "tsx dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@riftsend/shared": "workspace:*",
    "@riftsend/protocol": "workspace:*",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "prettier": "^3.8.4",
    "tsx": "^4.22.3",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@10.33.4"
}
