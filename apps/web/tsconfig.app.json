{
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],

    "module": "ESNext",
    "moduleResolution": "bundler",

    "types": ["vite/client"],

    "jsx": "react-jsx",

    "paths": {
      "@/*": ["./src/*"]
    },

    "allowImportingTsExtensions": true,
    "noEmit": true
  },

  "include": ["src"]
}
